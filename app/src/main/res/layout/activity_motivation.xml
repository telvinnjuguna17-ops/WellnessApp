<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MotivationActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Motivation"
            android:textSize="25sp"
            android:textAlignment="center"
            android:background="@drawable/shape"
            android:padding="10dp"
            android:textStyle="bold"
            android:textColor="#16165B"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quote of the Day"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/shape"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvQuote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The secret of getting ahead is getting started."
                android:textSize="17sp"
                android:textStyle="italic"
                android:textColor="#16165B"
                android:textAlignment="center"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/tvQuoteAuthor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mark Twain"
                android:textSize="14sp"
                android:textColor="#888888"
                android:textAlignment="center"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnNewQuote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="New Quote"
                android:backgroundTint="#16165B"
                android:textColor="#FFFFFF"/>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Daily Affirmation"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/shape"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvAffirmation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="I am capable of achieving great things. Every step I take brings me closer to my goals."
                android:textSize="15sp"
                android:textColor="#16165B"
                android:textAlignment="center"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnSaveAffirmation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save Affirmation"
                android:backgroundTint="#16165B"
                android:textColor="#FFFFFF"/>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="My Goals"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/shape"
            android:padding="14dp"
            android:layout_marginBottom="8dp">

            <CheckBox
                android:id="@+id/checkGoal1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#16165B"
                android:layout_marginEnd="10dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Exercise 3x this week"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 of 3 done"
                    android:textSize="13sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="67%"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#16165B"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/shape"
            android:padding="14dp"
            android:layout_marginBottom="8dp">

            <CheckBox
                android:id="@+id/checkGoal2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#16165B"
                android:layout_marginEnd="10dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Drink 2.5L of water daily"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 of 7 days"
                    android:textSize="13sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="71%"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#16165B"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/shape"
            android:padding="14dp"
            android:layout_marginBottom="8dp">

            <CheckBox
                android:id="@+id/checkGoal3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#16165B"
                android:checked="true"
                android:layout_marginEnd="10dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Meditate every morning"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7 of 7 days"
                    android:textSize="13sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100%"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#16165B"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp">

            <EditText
                android:id="@+id/etNewGoal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Add a new goal..."
                android:background="@drawable/shape"
                android:padding="12dp"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnAddGoal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add"
                android:backgroundTint="#16165B"
                android:textColor="#FFFFFF"/>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This Week"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/shape"
            android:padding="16dp"
            android:weightSum="7"
            android:layout_marginBottom="20dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="M" android:textSize="12sp" android:textColor="#888888"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Done" android:textSize="11sp" android:textColor="#2E7D32"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="T" android:textSize="12sp" android:textColor="#888888"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Done" android:textSize="11sp" android:textColor="#2E7D32"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="W" android:textSize="12sp" android:textColor="#888888"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Done" android:textSize="11sp" android:textColor="#2E7D32"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="T" android:textSize="12sp" android:textColor="#888888"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Done" android:textSize="11sp" android:textColor="#2E7D32"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="F" android:textSize="12sp" android:textColor="#888888"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--" android:textSize="11sp" android:textColor="#888888"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="S" android:textSize="12sp" android:textColor="#888888"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--" android:textSize="11sp" android:textColor="#888888"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="S" android:textSize="12sp" android:textColor="#888888"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--" android:textSize="11sp" android:textColor="#888888"/>
            </LinearLayout>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tip of the Day"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/shape"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvTip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Start small. Pick one habit, do it consistently for 21 days, and it will become second nature."
                android:textSize="14sp"
                android:textColor="#333333"
                android:lineSpacingExtra="4dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>