<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".NutritionActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nutrition"
            android:textSize="25sp"
            android:textAlignment="center"
            android:background="@drawable/shape"
            android:padding="10dp"
            android:textStyle="bold"
            android:textColor="#16165B"/>

        <!-- Calorie Summary -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Today's Calories"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/shape"
            android:padding="16dp"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvCaloriesConsumed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1,340"
                android:textSize="48sp"
                android:textStyle="bold"
                android:textColor="#16165B"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="of 2,000 kcal daily goal"
                android:textSize="14sp"
                android:textColor="#888888"
                android:layout_marginBottom="12dp"/>

            <ProgressBar
                android:id="@+id/progressBarCalories"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="16dp"
                android:max="100"
                android:progress="67"
                android:progressTint="#16165B"
                android:progressBackgroundTint="#DDDDDD"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="660 kcal remaining"
                android:textSize="13sp"
                android:textColor="#888888"/>

        </LinearLayout>

        <!-- Macronutrients -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Macronutrients"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="16dp">

            <!-- Carbs -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/shape"
                android:padding="12dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Carbs"
                    android:textSize="13sp"
                    android:textColor="#888888"/>

                <TextView
                    android:id="@+id/tvCarbs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="160g"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#16165B"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="of 250g"
                    android:textSize="11sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <!-- Protein -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/shape"
                android:padding="12dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Protein"
                    android:textSize="13sp"
                    android:textColor="#888888"/>

                <TextView
                    android:id="@+id/tvProtein"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="85g"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#16165B"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="of 120g"
                    android:textSize="11sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <!-- Fats -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/shape"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fats"
                    android:textSize="13sp"
                    android:textColor="#888888"/>

                <TextView
                    android:id="@+id/tvFats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="42g"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#16165B"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="of 65g"
                    android:textSize="11sp"
                    android:textColor="#888888"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Log a Meal -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Log a Meal"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etFoodName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Food name (e.g. Grilled Chicken)"
            android:background="@drawable/shape"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/etCalories"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Calories"
                android:inputType="number"
                android:background="@drawable/shape"
                android:padding="12dp"
                android:layout_marginEnd="6dp"/>

            <EditText
                android:id="@+id/etMealCarbs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Carbs (g)"
                android:inputType="number"
                android:background="@drawable/shape"
                android:padding="12dp"
                android:layout_marginEnd="6dp"/>

            <EditText
                android:id="@+id/etMealProtein"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Protein (g)"
                android:inputType="number"
                android:background="@drawable/shape"
                android:padding="12dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Spinner
                android:id="@+id/spinnerMealType"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/shape"
                android:padding="12dp"
                android:entries="@array/meal_types"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnLogMeal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Log Meal"
                android:backgroundTint="#16165B"
                android:textColor="#FFFFFF"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"/>

        </LinearLayout>

        <!-- Meals by Type -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Today's Meals"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Breakfast -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Breakfast"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#888888"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/shape"
            android:padding="14dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Oats with banana"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Carbs: 60g · Protein: 10g · Fats: 5g"
                    android:textSize="12sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="350 kcal"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#16165B"/>
        </LinearLayout>

        <!-- Lunch -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lunch"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#888888"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/shape"
            android:padding="14dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Grilled chicken and rice"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Carbs: 70g · Protein: 45g · Fats: 12g"
                    android:textSize="12sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="580 kcal"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#16165B"/>
        </LinearLayout>

        <!-- Snack -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Snack"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#888888"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/shape"
            android:padding="14dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Greek yoghurt"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Carbs: 10g · Protein: 15g · Fats: 3g"
                    android:textSize="12sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="160 kcal"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#16165B"/>
        </LinearLayout>

        <!-- Dinner placeholder -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dinner"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#888888"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/shape"
            android:padding="14dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nothing logged yet"
                android:textSize="14sp"
                android:textColor="#888888"
                android:fontFamily="sans-serif-light"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 kcal"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#BBBBBB"/>
        </LinearLayout>

        <!-- Water Intake -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Water Intake"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/shape"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="1.2L of 2.5L"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#16165B"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="48%"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#16165B"/>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressWater"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:max="100"
                android:progress="48"
                android:progressTint="#16165B"
                android:progressBackgroundTint="#DDDDDD"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>